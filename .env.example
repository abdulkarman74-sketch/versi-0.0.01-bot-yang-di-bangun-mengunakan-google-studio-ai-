# WhatsApp Bot Configuration
# Used for Pterodactyl Environment Variables or local .env file

# Nomor WhatsApp bot untuk pairing code (contoh: 6285814369350)
NUMBER=

# Nomor WhatsApp owner (contoh: 6285814369350)
OWNER=

# Nama bot Anda (default: Keyren)
BOT_NAME=Keyren

# Nama owner (default: Owner)
OWNER_NAME=Owner

# Prefix untuk command (default: .)
PREFIX=.

# Mode bot: public atau self (default: public)
MODE=public
